# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database (local default — override for Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/mood_of_the_major_dev

# Auth (required in production — dev uses fallback if JWT_SECRET unset)
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Cloudflare R2 (required in production)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

# Business config
AGGREGATION_THRESHOLD_MIN=5
BCRYPT_ROUNDS=12

# Internal jobs (POST /api/v1/internal/jobs/*)
SERVICE_API_KEY=

# Rate limits (optional overrides — defaults per docs/security.md)
# RATE_LIMIT_AUTH_MAX=10
# RATE_LIMIT_WRITE_MAX=30
# RATE_LIMIT_FEED_MAX=120
# RATE_LIMIT_GENERAL_MAX=300

# Image cleanup (POST /api/v1/internal/jobs/cleanup-images — schedule every 6h)
ORPHAN_IMAGE_TTL_HOURS=24
IMAGE_CLEANUP_BATCH_SIZE=100

# Optional error tracking (Sentry)
SENTRY_DSN=

# Optional: restrict registration email domains (comma-separated)
# ALLOWED_EMAIL_DOMAINS=university.edu

# OAuth (Google / GitHub) — callback URLs must match provider console settings
# FRONTEND_URL=http://localhost:5173
# OAUTH_CALLBACK_BASE_URL=http://localhost:5173/api/v1/auth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
