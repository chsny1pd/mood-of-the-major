# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database (local default — override for Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/mood_of_the_major_dev

# Auth (required in production — dev uses fallback if JWT_SECRET unset)
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Cloudflare R2 (required in production)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

# Business config
AGGREGATION_THRESHOLD_MIN=5
BCRYPT_ROUNDS=12

# Optional: restrict registration email domains (comma-separated)
# ALLOWED_EMAIL_DOMAINS=university.edu
